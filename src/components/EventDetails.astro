---
const details = [
  { icon: "calendar", label: "FECHA",  value: "Sábado 15 de Noviembre, 2025" },
  { icon: "clock",    label: "HORA",   value: "8:00 PM → Hasta que aguantes 🔥" },
  { icon: "map-pin",  label: "LUGAR",  value: "Hacienda Los Reyes, Guadalajara" },
];

const svgs: Record<string, string> = {
  calendar: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>`,
  clock:    `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  "map-pin":`<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
};
---

<section class="py-24 px-4">
  <div class="max-w-xl mx-auto text-center">
    <p class="text-xs tracking-[0.4em] text-magenta font-body mb-2 drop-shadow-lg">INFO IMPORTANTE</p>
    <h2 class="text-4xl sm:text-5xl font-display text-gradient-gold mb-12 drop-shadow-lg">Los Detalles</h2>
    <div class="flex flex-col gap-4">
      {details.map((d, i) => (
        <div
          class="flex items-center gap-4 p-5 rounded-xl bg-muted/40 border border-border text-left anim-slide"
          style={`animation-delay: ${i * 0.1}s`}
        >
          <span class="w-6 h-6 text-gold shrink-0" set:html={svgs[d.icon]} />
          <div>
            <p class="text-[10px] tracking-widest text-muted-foreground font-body mb-1">{d.label}</p>
            <p class="font-body font-medium text-foreground">{d.value}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .anim-slide {
    opacity: 0;
    animation: slideIn 0.5s ease-out both;
    animation-play-state: paused;
  }
  .anim-slide.visible {
    animation-play-state: running;
  }
  @keyframes slideIn {
    from { opacity: 0; transform: translateX(-20px); }
    to   { opacity: 1; transform: translateX(0); }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add("visible"); });
  }, { threshold: 0.1 });
  document.querySelectorAll(".anim-slide").forEach(el => observer.observe(el));
</script>
